generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

enum UserRole {
  CREATOR
  ADMIN
}

enum ApprovalStatus {
  NEEDS_ONBOARDING
  AWAITING_APPROVAL
  APPROVED
  REJECTED
}

enum Tier {
  BRONZE
  SILVER
  GOLD
}

enum DealStatus {
  DRAFT
  ACTIVE
  PAUSED
  COMPLETED
  ARCHIVED
}

enum ListingStatus {
  ACTIVE
  PAUSED
  ARCHIVED
}

enum OpportunityStatus {
  OPEN
  INVITE_ONLY
  CLOSED
}

enum EventType {
  VIEW
  CLICK
  PURCHASE
  IMPRESSION
}

model User {
  id                  String              @id @default(cuid())
  email               String?             @unique
  phone               String?             @unique
  passwordHash        String
  role                UserRole            @default(CREATOR)
  approvalStatus      ApprovalStatus      @default(NEEDS_ONBOARDING)
  onboardingCompleted Boolean             @default(false)
  createdAt           DateTime            @default(now())
  updatedAt           DateTime            @updatedAt

  creatorProfile      CreatorProfile?
  refreshTokens       RefreshToken[]
  deals               Deal[]
  listings            MarketplaceListing[]
  analyticsEvents     AnalyticsEvent[]
  mediaAssets         MediaAsset[]
  appRecords          AppRecord[]
}

model RefreshToken {
  id        String   @id
  userId    String
  tokenHash String
  family    String
  expiresAt DateTime
  revokedAt DateTime?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([family])
}

model CreatorProfile {
  id               String   @id @default(cuid())
  userId           String   @unique
  name             String
  handle           String   @unique
  tier             Tier     @default(BRONZE)
  tagline          String?
  bio              String?  @db.Text
  categories       String?  @db.Text
  regions          String?  @db.Text
  languages        String?  @db.Text
  followers        Int      @default(0)
  rating           Float    @default(0)
  totalSalesDriven Float    @default(0)
  isKycVerified    Boolean  @default(false)
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  user             User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Seller {
  id         String   @id @default(cuid())
  name       String
  type       String
  category   String?
  region     String?
  rating     Float    @default(0)
  isVerified Boolean  @default(false)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  opportunities Opportunity[]
}

model Opportunity {
  id          String            @id @default(cuid())
  sellerId    String
  title       String
  description String?           @db.Text
  payBand     String?
  status      OpportunityStatus @default(OPEN)
  createdAt   DateTime          @default(now())
  updatedAt   DateTime          @updatedAt

  seller      Seller            @relation(fields: [sellerId], references: [id], onDelete: Cascade)

  @@index([sellerId])
  @@index([status])
}

model Deal {
  id          String     @id @default(cuid())
  userId      String
  title       String
  description String?    @db.Text
  category    String?
  price       Float?
  currency    String     @default("USD")
  status      DealStatus @default(DRAFT)
  startAt     DateTime?
  endAt       DateTime?
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt

  user        User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  listings    MarketplaceListing[]

  @@index([userId])
  @@index([status])
}

model MarketplaceListing {
  id          String        @id @default(cuid())
  userId      String
  dealId      String?
  title       String
  description String?       @db.Text
  price       Float?
  currency    String        @default("USD")
  status      ListingStatus @default(ACTIVE)
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt

  user        User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  deal        Deal?         @relation(fields: [dealId], references: [id], onDelete: SetNull)

  @@index([userId])
  @@index([dealId])
  @@index([status])
}

model AnalyticsEvent {
  id        String    @id @default(cuid())
  userId    String
  eventType EventType
  value     Int?
  meta      String?   @db.Text
  createdAt DateTime  @default(now())

  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, eventType])
  @@index([createdAt])
}

model MediaAsset {
  id        String   @id @default(cuid())
  userId    String
  name      String
  kind      String
  url       String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model AppRecord {
  id         String   @id @default(cuid())
  userId     String?
  domain     String
  entityType String
  entityId   String?
  payload    Json
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  user       User?    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, domain, entityType])
  @@index([domain, entityType, entityId])
}
