model AdzBuilder {
  id          String   @id @default(cuid())
  userId      String
  status      String   @default("draft")
  published   Boolean  @default(false)
  publishedAt DateTime?
  data        Json?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, status])
}

model AdzCampaign {
  id        String   @id @default(cuid())
  userId    String
  status    String   @default("draft")
  title     String?
  budget    Float?
  currency  String   @default("USD")
  isMarketplace Boolean @default(false)
  data      Json?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user       User            @relation(fields: [userId], references: [id], onDelete: Cascade)
  performance AdzPerformance?

  @@index([userId, status])
}

model AdzPerformance {
  id         String   @id @default(cuid())
  campaignId String   @unique
  clicks     Int      @default(0)
  purchases  Int      @default(0)
  earnings   Float    @default(0)
  data       Json?
  updatedAt  DateTime @updatedAt

  campaign AdzCampaign @relation(fields: [campaignId], references: [id], onDelete: Cascade)
}

model AdzLink {
  id        String   @id @default(cuid())
  userId    String
  status    String   @default("active")
  url       String?
  data      Json?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, status])
}

model PromoAd {
  id        String   @id @default(cuid())
  userId    String
  status    String   @default("draft")
  data      Json?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, status])
}

model RegulatoryDesk {
  id        String   @id @default(cuid())
  userId    String
  slug      String
  title     String?
  status    String   @default("active")
  metadata  Json?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user  User               @relation(fields: [userId], references: [id], onDelete: Cascade)
  items RegulatoryDeskItem[]

  @@unique([userId, slug])
  @@index([userId, status])
}

model RegulatoryDeskItem {
  id        String   @id @default(cuid())
  deskId    String
  title     String?
  status    String   @default("open")
  severity  String?
  metadata  Json?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  desk RegulatoryDesk @relation(fields: [deskId], references: [id], onDelete: Cascade)

  @@index([deskId, status])
}

model RegulatoryComplianceItem {
  id        String   @id @default(cuid())
  userId    String
  itemType  String
  title     String?
  status    String   @default("open")
  metadata  Json?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, itemType])
}

model Review {
  id                String        @id @default(cuid())
  reviewerUserId    String?
  subjectType       ReviewSubject @default(CREATOR)
  subjectId         String
  subjectUserId     String?
  orderId           String?
  sessionId         String?
  campaignId        String?
  title             String?
  buyerName         String?
  buyerType         String?
  roleTarget        String?
  itemType          String?
  channel           String?
  marketplace       String?
  mldzSurface       String?
  sentiment         String?
  requiresResponse  Boolean       @default(false)
  resolvedAt        DateTime?
  flaggedAt         DateTime?
  ratingOverall     Float
  ratingBreakdown   Json?
  quickTags         Json?
  issueTags         Json?
  reviewText        String?       @db.Text
  wouldJoinAgain    Boolean?
  transactionIntent String?
  isPublic          Boolean       @default(true)
  isAnonymous       Boolean       @default(false)
  status            ReviewStatus  @default(PUBLISHED)
  metadata          Json?
  createdAt         DateTime      @default(now())
  updatedAt         DateTime      @updatedAt

  reviewer User? @relation("ReviewAuthor", fields: [reviewerUserId], references: [id], onDelete: SetNull)
  subject  User? @relation("ReviewSubject", fields: [subjectUserId], references: [id], onDelete: SetNull)
  replies  ReviewReply[]

  @@index([subjectType, subjectId])
  @@index([subjectUserId, createdAt])
  @@index([reviewerUserId, createdAt])
  @@index([status, createdAt])
  @@index([subjectUserId, status, createdAt])
  @@index([channel])
  @@index([marketplace])
  @@index([sentiment])
  @@index([requiresResponse])
  @@index([roleTarget])
  @@index([itemType])
  @@index([mldzSurface])
  @@index([orderId])
  @@index([sessionId])
  @@index([campaignId])
}

model ReviewReply {
  id           String               @id @default(cuid())
  reviewId     String
  authorUserId String?
  body         String               @db.Text
  visibility   ReviewReplyVisibility @default(PUBLIC)
  createdAt    DateTime             @default(now())
  updatedAt    DateTime             @updatedAt

  review Review @relation(fields: [reviewId], references: [id], onDelete: Cascade)
  author User?  @relation(fields: [authorUserId], references: [id], onDelete: SetNull)

  @@index([reviewId, createdAt])
  @@index([authorUserId])
}

model ListingInventorySlot {
  id          String   @id @default(cuid())
  listingId   String
  warehouseId String
  sku         String?
  onHand      Int      @default(0)
  reserved    Int      @default(0)
  safetyStock Int      @default(0)
  updatedAt   DateTime @updatedAt
  createdAt   DateTime @default(now())

  listing   MarketplaceListing @relation(fields: [listingId], references: [id], onDelete: Cascade)
  warehouse SellerWarehouse    @relation(fields: [warehouseId], references: [id], onDelete: Cascade)

  @@unique([listingId, warehouseId])
  @@index([warehouseId])
  @@index([listingId])
}

model InventoryAdjustment {
  id            String   @id @default(cuid())
  listingId     String
  warehouseId   String?
  createdByUserId String?
  delta         Int
  reason        String?
  metadata      Json?
  createdAt     DateTime @default(now())

  listing   MarketplaceListing @relation(fields: [listingId], references: [id], onDelete: Cascade)
  warehouse SellerWarehouse?   @relation(fields: [warehouseId], references: [id], onDelete: SetNull)
  createdBy User?              @relation(fields: [createdByUserId], references: [id], onDelete: SetNull)

  @@index([listingId, createdAt])
  @@index([warehouseId])
  @@index([createdByUserId])
}

model SellerDocument {
  id         String         @id @default(cuid())
  sellerId   String
  listingId  String?
  type       String
  channel    String?
  regions    Json?
  fileName   String?
  url        String?
  status     DocumentStatus @default(UPLOADED)
  uploadedAt DateTime       @default(now())
  expiresAt  DateTime?
  metadata   Json?
  createdAt  DateTime       @default(now())
  updatedAt  DateTime       @updatedAt

  seller  Seller              @relation(fields: [sellerId], references: [id], onDelete: Cascade)
  listing MarketplaceListing? @relation(fields: [listingId], references: [id], onDelete: SetNull)

  @@index([sellerId, status])
  @@index([listingId])
  @@index([expiresAt])
}

model SellerExportJob {
  id          String         @id @default(cuid())
  sellerId    String
  type        String
  status      ExportJobStatus @default(QUEUED)
  format      String         @default("CSV")
  requestedAt DateTime       @default(now())
  completedAt DateTime?
  fileUrl     String?
  filters     Json?
  metadata    Json?

  seller Seller @relation(fields: [sellerId], references: [id], onDelete: Cascade)

  @@index([sellerId, status])
  @@index([requestedAt])
}

model SellerReturn {
  id         String       @id @default(cuid())
  sellerId   String
  orderId    String
  status     ReturnStatus @default(REQUESTED)
  reason     String?
  notes      String?      @db.Text
  requestedAt DateTime    @default(now())
  approvedAt DateTime?
  receivedAt DateTime?
  refundedAt DateTime?
  metadata   Json?
  createdAt  DateTime     @default(now())
  updatedAt  DateTime     @updatedAt

  seller Seller @relation(fields: [sellerId], references: [id], onDelete: Cascade)
  order  Order  @relation(fields: [orderId], references: [id], onDelete: Cascade)

  @@index([sellerId, status])
  @@index([orderId])
}

model SellerDispute {
  id        String        @id @default(cuid())
  sellerId  String
  orderId   String
  status    DisputeStatus @default(OPEN)
  reason    String?
  openedAt  DateTime      @default(now())
  resolvedAt DateTime?
  metadata  Json?
  createdAt DateTime      @default(now())
  updatedAt DateTime      @updatedAt

  seller Seller @relation(fields: [sellerId], references: [id], onDelete: Cascade)
  order  Order  @relation(fields: [orderId], references: [id], onDelete: Cascade)

  @@index([sellerId, status])
  @@index([orderId])
}
