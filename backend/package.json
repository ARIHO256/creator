{
  "name": "mylivedealz-creator-backend",
  "version": "2.0.0",
  "private": true,
  "type": "module",
  "description": "NestJS + Prisma + MySQL backend for the MyLiveDealz Creator App",
  "scripts": {
    "dev": "/bin/bash -lc 'npm run build && trap \"kill 0\" EXIT; tsc -p tsconfig.build.json --watch --preserveWatchOutput & node --watch dist/main.js'",
    "start": "npm run build && node dist/main.js",
    "build": "tsc -p tsconfig.build.json",
    "start:prod": "node dist/main.js",
    "prisma:generate": "prisma generate",
    "prisma:migrate": "prisma migrate dev",
    "prisma:deploy": "prisma migrate deploy",
    "prisma:seed:loadtest": "node prisma/seed-loadtest.mjs",
    "seller:import-provider-service-taxonomy": "node --env-file=.env --import tsx scripts/import-provider-service-taxonomy.ts",
    "test": "tsx --test test/**/*.test.ts"
  },
  "dependencies": {
    "@nestjs/common": "^11.0.0",
    "@nestjs/config": "^4.0.0",
    "@nestjs/core": "^11.0.0",
    "@nestjs/jwt": "^11.0.0",
    "@nestjs/mapped-types": "^2.1.0",
    "@nestjs/platform-fastify": "^11.0.0",
    "@prisma/client": "^6.0.0",
    "bcrypt": "^5.1.1",
    "class-transformer": "^0.5.1",
    "class-validator": "^0.14.2",
    "fastify": "^5.0.0",
    "ioredis": "^5.4.1",
    "prom-client": "^15.1.3",
    "reflect-metadata": "^0.2.2",
    "rxjs": "^7.8.1"
  },
  "devDependencies": {
    "@types/bcrypt": "^5.0.2",
    "@types/node": "^22.0.0",
    "prisma": "^6.0.0",
    "tsx": "^4.7.0",
    "typescript": "^5.7.0"
  },
  "engines": {
    "node": ">=20.19.0"
  }
}
