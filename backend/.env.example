DATABASE_URL="mysql://root:root@127.0.0.1:3306/mldz_creator"
DATABASE_READ_URL="mysql://root:root@127.0.0.1:3306/mldz_creator"
DATABASE_QUERY_BUDGET_MS=75
DATABASE_READ_FALLBACK_ENABLED=true
REDIS_URL="redis://127.0.0.1:6379"
PORT=4010
HOST=0.0.0.0
NODE_ENV=development
APP_REGION=local
INSTANCE_ID=""
TRUST_PROXY=true
REQUEST_TIMEOUT_MS=15000
KEEP_ALIVE_TIMEOUT_MS=72000
CONNECTION_TIMEOUT_MS=5000
MAX_REQUESTS_PER_SOCKET=1000
BODY_LIMIT_BYTES=10485760

JWT_ACCESS_SECRET="replace-with-strong-access-secret"
JWT_ACCESS_TTL="15m"
JWT_REFRESH_SECRET="replace-with-strong-refresh-secret"
JWT_REFRESH_TTL_DAYS=30

AUTH_REGISTER_QUEUE_ENABLED=true
AUTH_REGISTER_QUEUE_SECRET="replace-with-strong-registration-queue-secret"
AUTH_REGISTER_POLL_AFTER_MS=1000

JOBS_WORKER_ENABLED=true
JOBS_WORKER_ID=api
JOBS_WORKER_POLL_MS=500
JOBS_WORKER_BUSY_POLL_MS=50
JOBS_WORKER_BATCH=50
JOBS_WORKER_CONCURRENCY=25
JOBS_WORKER_QUEUES=
JOBS_WORKER_LOCK_TTL_MS=600000

RATE_LIMIT_DEFAULT_LIMIT=120
RATE_LIMIT_DEFAULT_WINDOW_MS=60000
RATE_LIMIT_AUTH_LIMIT=12
RATE_LIMIT_AUTH_WINDOW_MS=60000
RATE_LIMIT_DISABLED=false

CACHE_DEFAULT_TTL_MS=15000
CACHE_PUBLIC_READ_TTL_MS=60000
CACHE_PUBLIC_FEED_TTL_MS=30000
CACHE_STOREFRONT_TTL_MS=120000
CACHE_TAXONOMY_TTL_MS=300000
CACHE_SUMMARY_TTL_MS=30000
CACHE_MAX_ENTRIES=5000
CACHE_REDIS_TIMEOUT_MS=150
CACHE_REDIS_CIRCUIT_FAILURE_THRESHOLD=5
CACHE_REDIS_CIRCUIT_RESET_MS=10000
CACHE_WARM_LISTINGS_LIMIT=24
HTTP_CACHE_CONTROL_ENABLED=true

REALTIME_ENABLED=true
REALTIME_REDIS_URL="redis://127.0.0.1:6379"
REALTIME_STREAM_SERVER_ENABLED=true
REALTIME_SUBSCRIBER_ENABLED=true
REALTIME_STREAM_MAX_PER_USER=3
REALTIME_STREAM_MAX_TOTAL=5000

FASTIFY_LOGGER=true
REQUEST_LOGS_ENABLED=true
LOAD_TEST_MODE=false

OTEL_ENABLED=false
OTEL_SERVICE_NAME="mldz-backend"
OTEL_SERVICE_VERSION="2.0.0"
OTEL_EXPORTER_OTLP_ENDPOINT=""
